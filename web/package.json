{
  "name": "thru-workspace",
  "version": "0.0.1",
  "private": true,
  "packageManager": "pnpm@10.33.4",
  "scripts": {
    "build": "pnpm -r build",
    "test": "pnpm -r --filter './packages/*' --filter './packages-private/*' test:run",
    "test:watch": "pnpm -r --filter './packages/*' --filter './packages-private/*' test:watch",
    "test:coverage": "pnpm -r --filter './packages/*' --filter './packages-private/*' test:coverage",
    "test:wallet": "pnpm --filter thru-wallet test",
    "test:sdk": "pnpm --filter @thru/sdk test"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.1.7",
    "tsup": "^8.5.1",
    "vitest": "^4.1.7"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@bufbuild/buf",
      "esbuild"
    ]
  }
}
