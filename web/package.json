{
  "name": "thru-workspace",
  "version": "0.0.1",
  "private": true,
  "packageManager": "pnpm@10.33.4",
  "scripts": {
    "build": "pnpm -r build",
    "test": "pnpm -r --if-present --filter './packages/*' --filter './packages-private/*' --filter './wallet/frontend/packages/*' --filter './wallet/packages/*' test:run",
    "test:watch": "pnpm -r --if-present --filter './packages/*' --filter './packages-private/*' --filter './wallet/frontend/packages/*' --filter './wallet/packages/*' test:watch",
    "test:coverage": "pnpm -r --if-present --filter './packages/*' --filter './packages-private/*' --filter './wallet/frontend/packages/*' --filter './wallet/packages/*' test:coverage",
    "test:wallet": "pnpm --filter thru-wallet test",
    "test:sdk": "pnpm --filter @thru/sdk test"
  },
  "devDependencies": {
    "@babel/generator": "^7.29.7",
    "@babel/traverse": "^7.29.7",
    "@babel/types": "^7.29.7",
    "@vitest/coverage-v8": "^4.1.7",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.7"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@bufbuild/buf",
      "esbuild"
    ],
    "overrides": {
      "esbuild@<0.25.0": "^0.25.0",
      "uuid@<11.1.1": ">=11.1.1"
    }
  }
}
