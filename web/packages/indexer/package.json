{
  "name": "@thru/indexer",
  "version": "0.1.0",
  "private": false,
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "dev": "tsx watch src/index.ts",
    "test": "vitest run",
    "test:run": "vitest run",
    "lint": "eslint src/"
  },
  "dependencies": {
    "@thru/sdk": "workspace:*",
    "drizzle-orm": "^0.45.2",
    "zod": "^4.4.3"
  },
  "peerDependencies": {
    "@thru/replay": "workspace:*",
    "postgres": "^3.4.0"
  },
  "devDependencies": {
    "@thru/replay": "workspace:*",
    "@types/node": "^25.9.1",
    "postgres": "^3.4.9",
    "tsup": "^8.5.1",
    "tsx": "^4.23.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.7"
  }
}
