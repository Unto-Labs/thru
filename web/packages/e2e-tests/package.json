{
  "name": "@thru/e2e-tests",
  "version": "0.0.1",
  "type": "module",
  "private": true,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "thru-e2e": "./dist/cli/run-e2e.js"
  },
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "e2e": "tsx src/cli/run-e2e.ts",
    "test": "vitest run",
    "test:watch": "vitest --watch",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@thru/thru-sdk": "workspace:*",
    "@thru/crypto": "workspace:*",
    "@thru/helpers": "workspace:*",
    "@thru/proto": "workspace:*",
    "@bufbuild/protobuf": "^2.9.0",
    "@connectrpc/connect": "^2.1.0",
    "@connectrpc/connect-node": "^2.1.0",
    "@noble/ed25519": "^2.3.0",
    "@noble/hashes": "^1.7.1",
    "commander": "^12.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsup": "^8.4.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
